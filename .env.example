# Copy to ".env" (never commit .env). Restart dev server after changes.

# Default catalog mode is admin-proxy (no Storefront token in the browser).
# `admin-proxy` — Browser calls /api/shopify/catalog/* ; Node uses Admin API (below).
#   Local: npm run dev (Vite middleware) or npm start (production-server.mjs).
#   Render: set SHOPIFY_* below + Build `npm run build`, Start `npm start`.
# `storefront` — Browser GraphQL only; set VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN.
# VITE_SHOPIFY_CATALOG_SOURCE=admin-proxy

# Store hostname only (no https://)
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API access token — only when VITE_SHOPIFY_CATALOG_SOURCE=storefront.
# Create in Shopify Admin → Settings → Apps and sales channels → Develop apps → [Your app]
# → Configuration → Storefront API → Install app → Storefront API access token
# DO NOT use Admin API tokens (shpat_*) in the frontend — they must stay server-side only.
VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Optional API version (default 2024-10)
# VITE_SHOPIFY_API_VERSION=2024-10

# Optional: public storefront URL if you use a custom domain (product links). Defaults to https://{domain}
# VITE_SHOPIFY_PUBLIC_STORE_URL=https://www.yourdomain.com

# Optional: collection handles from Shopify Admin → Collections (URL handle/slug)
# VITE_SHOPIFY_COLLECTION_MAGHREB=mystery-of-the-maghreb
# VITE_SHOPIFY_COLLECTION_OPULENCE=french-opulence-edition

# Products per page / load-more chunk (max 50)
# VITE_SHOPIFY_PRODUCTS_PAGE_SIZE=8

# Set to true to always print masked token info + shop ping in the browser console (npm run dev also logs).
# VITE_SHOPIFY_DEBUG=true

# --- Admin REST API (server only — NEVER use VITE_ prefix; never bundle into the browser) ---
# Used by: catalog API (/api/shopify/catalog), npm run admin:create-product | admin:list-products
# Scripts read this file automatically (no dotenv npm package). Do not hardcode tokens in .js files.
# --- Render (Web Service + npm start) — REQUIRED for live catalog ---
# Dashboard → your service → Environment → add exactly (no VITE_ prefix):
#   SHOPIFY_ADMIN_ACCESS_TOKEN = paste Admin API token from Shopify (Apps → your app → API credentials).
#   Same string Postman uses as X-Shopify-Access-Token. Save, then redeploy (Manual Deploy).
# If products work locally but fail on Render, the token here is missing/wrong/expired — rotate in Shopify if needed.
# Shop defaults in server/shopify-settings.mjs — optional override:
# SHOPIFY_SHOP_DOMAIN=royalanci.myshopify.com
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_your_admin_token_from_shopify
# SHOPIFY_ADMIN_API_VERSION=2026-04

# Optional: allow POST/PUT/DELETE via /api/shopify/admin/... (same paths as Postman). Default: GET only.
# SHOPIFY_ADMIN_PROXY_ALLOW_WRITE=true
